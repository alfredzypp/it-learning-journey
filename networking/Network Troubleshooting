## 创建诊断脚本

### 快速网络诊断脚本
```bash
#!/bin/bash
# network-diag.sh - 快速网络诊断

echo "========== 网络诊断工具 =========="
echo ""

echo "1. 网卡状态："
ip link show | grep -E "^[0-9]|state"
echo ""

echo "2. IP 配置："
ip -4 addr show | grep -E "inet |^[0-9]"
echo ""

echo "3. 默认网关："
ip route | grep default
echo ""

echo "4. DNS 配置："
cat /etc/resolv.conf | grep nameserver
echo ""

echo "5. 测试本地连接："
ping -c 3 127.0.0.1 > /dev/null 2>&1 && echo "✓ 本地回环正常" || echo "✗ 本地回环失败"
echo ""

echo "6. 测试网关连接："
GATEWAY=$(ip route | grep default | awk '{print $3}')
if [ -n "$GATEWAY" ]; then
    ping -c 3 $GATEWAY > /dev/null 2>&1 && echo "✓ 网关 ($GATEWAY) 可达" || echo "✗ 网关 ($GATEWAY) 不可达"
else
    echo "✗ 未找到默认网关"
fi
echo ""

echo "7. 测试外网连接："
ping -c 3 8.8.8.8 > /dev/null 2>&1 && echo "✓ 外网 (8.8.8.8) 可达" || echo "✗ 外网 (8.8.8.8) 不可达"
echo ""

echo "8. 测试 DNS 解析："
ping -c 3 google.com > /dev/null 2>&1 && echo "✓ DNS 解析正常" || echo "✗ DNS 解析失败"
echo ""

echo "9. 防火墙状态："
sudo systemctl is-active firewalld > /dev/null 2>&1 && echo "防火墙运行中" || echo "防火墙已停止"
echo ""

echo "10. 监听端口："
echo "开放的端口："
sudo ss -tulpn | grep LISTEN | awk '{print $5}' | cut -d: -f2 | sort -u
echo ""

echo "========== 诊断完成 =========="
```

保存并运行：
```bash
chmod +x network-diag.sh
./network-diag.sh
```

### 连接监控脚本
```bash
#!/bin/bash
# connection-monitor.sh - 监控网络连接

LOG_FILE="connection.log"

echo "开始监控网络连接... (Ctrl+C 停止)"
echo "日志保存在: $LOG_FILE"

while true; do
    TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
    
    # Ping 测试
    if ping -c 1 -W 2 8.8.8.8 > /dev/null 2>&1; then
        echo "$TIMESTAMP - OK" | tee -a $LOG_FILE
    else
        echo "$TIMESTAMP - FAILED!" | tee -a $LOG_FILE
        
        # 连接失败时记录详细信息
        echo "--- 诊断信息 ---" >> $LOG_FILE
        ip addr show >> $LOG_FILE
        ip route show >> $LOG_FILE
        echo "---------------" >> $LOG_FILE
    fi
    
    sleep 5
done
```

